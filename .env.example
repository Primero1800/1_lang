APP_NAME=1_Lang
APP_VERSION=0.1.0

POSTGRES_HOST=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
POSTGRES_DB=${APP_NAME}

POOL_SIZE=10
MAX_OVERFLOW=10
POOL_TIMEOUT=30
POOL_RECYCLE=1800

LOG_LEVEL=DEBUG

AIOHTTP_KEEPALIVE_TIMEOUT=30
AIOHTTP_TIMEOUT_SECONDS=60

HEALTH_CHECK_TIMEOUT_SEC=5

# [AI] Mistral
MISTRAL_API_KEY=your_key_here
MISTRAL_MODEL=mistral-small-latest
MISTRAL_EMBED_MODEL=mistral-embed
MISTRAL_TIMEOUT_SEC=60
MISTRAL_VISION_TIMEOUT_SEC=120

QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT__SERVICE__API_KEY=myapikeyformyqdrant
QDRANT_TIMEOUT=60
QDRANT_MAIN_ENABLED=False
QDRANT_MAIN_URL=https://your-cluster.cloud.qdrant.io
QDRANT_MAIN_API_KEY=your_key_here
T1_SEARCH_MIN_SCORE=0.85
VECTOR_DB_COLLECTION=talks
VECTOR_DB_VECTOR_SIZE=1024

# [AI] Groq
GROQ_API_KEY=your_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_TIMEOUT_SEC=30

# [Redis]
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_TOKENS_STREAM=stream:tokens
REDIS_TOKENS_GROUP=token_workers
REDIS_TOKENS_WORKER=main
REDIS_TOKENS_BATCH_SIZE=100
REDIS_TOKENS_POLL_INTERVAL=60

# [LangSmith]
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_key_here
LANGCHAIN_PROJECT=${APP_NAME}
