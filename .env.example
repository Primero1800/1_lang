APP_NAME=1_Lang
APP_VERSION=0.1.0

POSTGRES_HOST=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
POSTGRES_DB=1_Lang

POOL_SIZE=10
MAX_OVERFLOW=10
POOL_TIMEOUT=30
POOL_RECYCLE=1800

LOG_LEVEL=DEBUG

AIOHTTP_KEEPALIVE_TIMEOUT=30
AIOHTTP_TIMEOUT_SECONDS=30

HEALTH_CHECK_TIMEOUT_SEC=5

# [AI] Mistral
MISTRAL_API_KEY=your_key_here
MISTRAL_MODEL=mistral-small-latest
MISTRAL_EMBED_MODEL=mistral-embed
MISTRAL_TIMEOUT_SEC=30

QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT__SERVICE__API_KEY=myapikeyformyqdrant
VECTOR_DB_COLLECTION=talks